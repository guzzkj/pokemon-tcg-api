{
  "info": {
    "_postman_id": "9e3d7cf8-4a3f-4b4a-a111-2f9f31d2b8a6",
    "name": "Pokemon TCG API RESTful",
    "description": "Colecao de testes para a API Pokemon TCG. Execute primeiro 'Gerar API Key' e copie o campo 'chave' para a variavel apiKey.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "",
      "type": "string"
    },
    {
      "key": "idempotencyKey",
      "value": "postman-{{$timestamp}}",
      "type": "string"
    },
    {
      "key": "cartaId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "colecaoId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "serieId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "tipoId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "detalheId",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apiKey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Gerar API Key",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api-keys?nomeCliente=avaliador",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api-keys"
              ],
              "query": [
                {
                  "key": "nomeCliente",
                  "value": "avaliador"
                }
              ]
            },
            "description": "Rota publica. Copie o valor de 'chave' retornado para a variavel apiKey."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API Key criada', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.chave) {",
                  "    pm.collectionVariables.set('apiKey', body.chave);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Swagger UI",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/swagger-ui.html",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "swagger-ui.html"
              ]
            }
          }
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api-docs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api-docs"
              ]
            }
          }
        }
      ]
    },
