            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Charizard Postman\",\n  \"categoria\": \"POKEMON\",\n  \"pontosDeVida\": 120,\n  \"imagemUrl\": \"https://assets.tcgdex.net/pt/base/base1/4/high.png\",\n  \"numeroLocal\": \"4\",\n  \"idExterno\": \"postman-{{$timestamp}}\"\n}"
            },
